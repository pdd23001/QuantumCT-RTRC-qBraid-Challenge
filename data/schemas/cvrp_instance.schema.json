{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quantum Courier CVRP Instance",
  "type": "object",
  "required": ["instance_name", "depot", "vehicles", "capacity", "customers"],
  "additionalProperties": false,
  "properties": {
    "instance_name": {
      "type": "string",
      "minLength": 1
    },
    "depot": {
      "type": "object",
      "required": ["id", "x", "y"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "const": 0
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "vehicles": {
      "type": "integer",
      "minimum": 1
    },
    "capacity": {
      "type": "integer",
      "minimum": 1
    },
    "customers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "x", "y"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          }
        }
      }
    },
    "qaoa": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reps": {
          "type": "integer",
          "minimum": 1
        },
        "optimizer": {
          "type": "string",
          "minLength": 1
        },
        "maxiter": {
          "type": "integer",
          "minimum": 1
        },
        "shots": {
          "type": "integer",
          "minimum": 1
        },
        "sampler_mode": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
